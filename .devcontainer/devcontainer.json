{
  "name": "Roadplanner",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "editor.formatOnSave": false,
        "files.trimTrailingWhitespace": true
      }
    }
  },
  "postCreateCommand": "python tools/validate_repository.py --quick",
  "remoteUser": "vscode"
}
